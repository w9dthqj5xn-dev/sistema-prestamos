# CONFIGURACIÓN DE FIREBASE (OPCIONAL - Para futuras migraciones)
# Copiar este archivo como .env y reemplazar con tus valores

# Credenciales de Firebase
FIREBASE_API_KEY=your_api_key_here
FIREBASE_PROJECT_ID=sistema-prestamos
FIREBASE_STORAGE_BUCKET=sistema-prestamos.appspot.com
FIREBASE_MESSAGING_SENDER_ID=your_sender_id
FIREBASE_APP_ID=your_app_id

# Configuración de la aplicación
APP_NAME=Sistema de Préstamos
APP_VERSION=1.0.0

# URLs de despliegue
NETLIFY_URL=https://sistema-prestamos.netlify.app
FIREBASE_URL=https://sistema-prestamos.web.app
